{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Launch (CheckingAccountMS)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/MicroServices/CheckingAccountMS/CheckingAccount.API/bin/Debug/net9.0/CheckingAccount.API.dll",
            "args": [],
            "cwd": "${workspaceFolder}/MicroServices/CheckingAccountMS/CheckingAccount.API",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:7136"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        },
        {
            "name": ".NET Core Launch (TransferMS)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/MicroServices/TransferMS/Transfer.API/bin/Debug/net9.0/Transfer.API.dll",
            "args": [],
            "cwd": "${workspaceFolder}/MicroServices/TransferMS/Transfer.API",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:7099"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        }
    ],
    "compounds": [
    {
      "name": "Run Both Microservices",
      "configurations": [
        ".NET Core Launch (CheckingAccountMS)",
        ".NET Core Launch (TransferMS)"
      ]
    }
  ]
}